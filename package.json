{
  "name": "ai-control",
  "version": "1.0.0",
  "description": "MCP server for full macOS control — terminal, filesystem, Docker, AppleScript, processes, and documents",
  "license": "MIT",
  "author": "luckyguy",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "ai-control": "dist/index.js"
  },
  "preferGlobal": true,
  "files": [
    "dist"
  ],
  "scripts": {
    "postinstall": "node dist/npm-scripts/verify-ripgrep.js || true",
    "build": "tsc && shx cp track-installation.js dist/ && shx chmod +x dist/*.js && shx mkdir -p dist/data && shx cp src/data/onboarding-prompts.json dist/data/ && node scripts/build-ui-runtime.cjs",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "start:debug": "node --inspect-brk=9229 dist/index.js",
    "prepare": "npm run build",
    "clean": "shx rm -rf dist",
    "test": "npm run build && node test/run-all-tests.js",
    "link:local": "npm run build && npm link",
    "unlink:local": "npm unlink",
    "inspector": "npx @modelcontextprotocol/inspector dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "macos",
    "terminal",
    "claude",
    "ai",
    "process-management",
    "file-editing",
    "code-editing",
    "applescript",
    "docker",
    "file-system",
    "text-manipulation",
    "code-modification"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "@opendocsg/pdf2md": "^0.2.2",
    "@supabase/supabase-js": "^2.89.0",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@vscode/ripgrep": "^1.15.9",
    "cross-fetch": "^4.1.0",
    "exceljs": "^4.4.0",
    "fastest-levenshtein": "^1.0.16",
    "file-type": "^21.1.1",
    "glob": "^10.3.10",
    "highlight.js": "^11.11.1",
    "isbinaryfile": "^5.0.4",
    "markdown-it": "^14.1.0",
    "md-to-pdf": "^5.2.5",
    "open": "^10.2.0",
    "pdf-lib": "^1.17.1",
    "pizzip": "^3.2.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "sharp": "^0.34.5",
    "tiptap-markdown": "^0.9.0",
    "unified": "^11.0.5",
    "unpdf": "^1.4.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.23.5"
  },
  "optionalDependencies": {
    "caffeinate": "^1.0.1"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^1.2.0",
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@types/node": "^20.17.24",
    "commander": "^13.1.0",
    "esbuild": "^0.27.2",
    "js-tiktoken": "^1.0.21",
    "jsdom": "^24.1.3",
    "nexe": "^5.0.0-beta.4",
    "nodemon": "^3.0.2",
    "shx": "^0.3.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
